@startuml casos_de_uso_00_general
' Selva Booking - Vista general
top to bottom direction
skinparam shadowing false
skinparam packageStyle rectangle
skinparam usecase {
  BackgroundColor #F3F1EA
  BorderColor #2E5E3E
}
skinparam actor {
  BorderColor #2E5E3E
}

title Selva Booking - Diagrama General de Casos de Uso

actor "Invitado" as INV
actor "Cliente" as CLI
actor "Administrador" as ADM

rectangle "Sistema Selva Booking" {

  package "Acceso al sistema" #E8EDE9 {
    usecase "Iniciar sesion" as UC02
    usecase "Registrarse" as UC03
    usecase "Recuperar contraseña" as UC04
    usecase "Cerrar sesion" as UC05
  }

  package "Modulo Cliente" #E8EDE9 {
    usecase "Explorar y buscar hoteles" as UC12
    usecase "Ver detalle de hotel" as UC15
    usecase "Completar reserva" as UC18
    usecase "Realizar pago" as UC22
    usecase "Gestionar mis reservas" as UC30
    usecase "Gestionar mi cuenta" as UC33
  }

  package "Modulo Administrador" #E8EDE9 {
    usecase "Ver dashboard" as UC38
    usecase "Gestionar solicitudes admin" as UC41
    usecase "Gestionar hoteles" as UC44
    usecase "Gestionar habitaciones" as UC50
    usecase "Gestionar reservas" as UC56
  }

  package "Compartido" #E8EDE9 {
    usecase "Consultar soporte" as UC66
  }
}

INV --> UC02
INV --> UC03
INV --> UC04

CLI --> UC05
CLI --> UC12
CLI --> UC15
CLI --> UC18
CLI --> UC22
CLI --> UC30
CLI --> UC33
CLI --> UC66

ADM --> UC05
ADM --> UC38
ADM --> UC41
ADM --> UC44
ADM --> UC50
ADM --> UC56
ADM --> UC33
ADM --> UC66

UC15 ..> UC12 : <<extend>>
UC18 ..> UC15 : <<extend>>
UC22 ..> UC18 : <<extend>>
UC30 ..> UC22 : <<extend>>
UC50 ..> UC44 : <<extend>>
UC56 ..> UC38 : <<extend>>

@enduml

